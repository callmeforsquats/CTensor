{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CUDA/C++ Debug",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        { "name": "PATH", "value": "${env:PATH};C:\\Program Files\\NVIDIA GPU Computing Toolkit\\CUDA\\v13.2\\bin" }
      ],
      "console": "integratedTerminal"
    }
  ]
}
