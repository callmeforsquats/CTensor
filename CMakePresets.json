{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_CUDA_HOST_COMPILER": "cl.exe",
        "CMAKE_C_COMPILER_TARGET": "x86_64-pc-windows-msvc",
        "CMAKE_CXX_COMPILER_TARGET": "x86_64-pc-windows-msvc"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug (Clang)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TREN_DEBUG": "ON",
        "TREN_TESTS": "ON"
      }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release (Clang)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TREN_DEBUG": "OFF"
      }
    }
  ]
}
